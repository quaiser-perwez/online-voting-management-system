<!DOCTYPE html>
<html>
<head>
  <title>Vote</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    h1 { color: #28a745; }
    .voter-info { background-color: #f0f0f0; padding: 10px; border-radius: 5px; margin-bottom: 20px; }
    .candidate-btn { display: block; margin: 10px 0; padding: 10px; background-color: #28a745; color: white; border: none; border-radius: 3px; cursor: pointer; width: 200px; }
    .candidate-btn:hover { background-color: #218838; }
    a { color: #28a745; text-decoration: none; margin-top: 20px; display: inline-block; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <h1>Cast Your Vote</h1>
  
  <div class="voter-info">
    <p><strong>Voter Email:</strong> <%= voter.email %></p>
  </div>

  <h3>Select a Candidate:</h3>
  <div>
    <% candidates.forEach(candidate => { %>
      <form method="POST" action="/vote/<%= candidate._id %>" style="display: inline;">
        <input type="hidden" name="voterId" value="<%= voter._id %>">
        <button type="submit" class="candidate-btn"><%= candidate.name %></button>
      </form>
    <% }); %>
  </div>

  <a href="/">Back to Home</a>
</body>
</html>
