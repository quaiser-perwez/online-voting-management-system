<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Admin Panel - Indian Voting System</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>
            <li><a href="/admin/add-voter">Add Voter</a></li>
            <li><a href="/admin/results">View Results</a></li>
            <li><a href="/admin/logout">Logout</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <div class="card india-card">
            <h3>➕ Add New Candidate</h3>
            <form action="/admin/add-candidate" method="POST">
                <div class="form-group">
                    <label>Candidate Name</label>
                    <input type="text" name="name" required />
                </div>
                <div class="form-group">
                    <label>Party</label>
                    <input type="text" name="party" required />
                </div>
                <button type="submit" class="btn india-btn-primary" style="width:100%">Add Candidate</button>
            </form>
        </div>

        <div class="card india-card manage-card">
            <h3>📋 Manage Candidates</h3>

            <table class="manage-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Party</th>
                        <th>Votes</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% candidates.forEach(c=> { %>
                        <tr>
                            <td>
                                <%= c.ID %>
                            </td>
                            <td>
                                <%= c.NAME %>
                            </td>
                            <td>
                                <%= c.PARTY %>
                            </td>
                            <td>
                                <%= c.VOTES %>
                            </td>
                            <td>
                                <a href="/admin/delete/<%= c.ID %>" class="btn btn-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

</body>

</html>