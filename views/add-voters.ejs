<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Voter</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="india-theme">

<nav class="india-nav">
  <div class="nav-brand">
    <div class="ashoka-chakra">⊛</div>
    <div class="logo-text">Admin Panel 🛡️</div>
  </div>
  <ul>
    <li><a href="/admin">Back to Admin</a></li>
    <li><a href="/admin/logout">Logout</a></li>
  </ul>
</nav>

<div class="flag-stripe"></div>

<div class="container" style="max-width:400px;">
  <div class="card india-card">
    <h2 style="text-align:center;">➕ Add New Voter</h2>

    <% if (error) { %>
      <p style="color:red; text-align:center;"><%= error %></p>
    <% } %>

    <% if (success) { %>
      <p style="color:green; text-align:center;"><%= success %></p>
    <% } %>

    <form action="/admin/add-voter" method="POST">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="username" required />
      </div>
      <div class="form-group">
        <label>Voter ID</label>
        <input type="text" name="voterId" required />
      </div>
     
      <button type="submit" class="btn india-btn-primary" style="width:100%;">
        Add Voter
      </button>
    </form>
  </div>
</div>

</body>
</html>