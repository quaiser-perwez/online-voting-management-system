<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Vote Now</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Vote Now</div>
        </div>
        <ul>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <h2 style="text-align:center;">🇮🇳 Choose Your Candidate 🇮🇳</h2>

        <div class="candidate-grid">
            <% candidates.forEach(c=> { %>
                <% const name = c.NAME || c.name || 'Unknown'; %>
                <% const party = c.PARTY || c.party || ''; %>
                <% const id = (c.ID !== undefined) ? c.ID : c.id; %>
                <% const votes = (c.VOTES !== undefined) ? c.VOTES : c.votes || 0; %>
                <div class="candidate-card">
                    <h3><%= name %></h3>
                    <p><%= party %></p>
                    <p style="font-size:0.9rem; color:#555; margin:8px 0;">Votes: <%= votes %></p>
                    <form action="/vote/<%= id %>" method="POST">
                        <button type="submit" class="btn india-btn-primary">Vote Now</button>
                    </form>
                </div>
            <% }) %>
        </div>
    </div>

</body>

</html>