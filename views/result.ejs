<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Live Results</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Election Results</div>
        </div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/login">Login</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <h2 style="text-align:center;">🇮🇳 Live Election Results 🇮🇳</h2>

        <div class="card india-card" style="text-align:center; background: linear-gradient(135deg, #fff9e6 0%, #e8f5e9 100%); margin-bottom:30px;">
            <% let totalVotes = 0;
               candidates.forEach(c=> {
                   const v = (c.VOTES !== undefined) ? c.VOTES : (c.votes || 0);
                   totalVotes += v;
               });
            %>
            <h3 style="color:#138808; margin:10px 0;">📊 Total Votes Cast</h3>
            <p style="font-size:2.5rem; color:#0047AB; font-weight:bold; margin:15px 0;"><%= totalVotes %></p>
            <p style="color:#666; margin:0;">Votes received in this election</p>
        </div>

        <div class="card india-card">

            <% candidates.forEach(c=> {
                   const name = c.NAME || c.name || 'Unknown';
                   const party = c.PARTY || c.party || '';
                   const votes = (c.VOTES !== undefined) ? c.VOTES : (c.votes || 0);
                   let percent = totalVotes === 0 ? 0 : Math.round((votes / totalVotes) * 100);
            %>
                <div class="result-item">
                    <strong><%= name %> (<%= party %>)</strong> - <%= votes %> votes
                    <div class="progress-bar-tag">
                        <div class="progress-bar-fill" style="width: <%= percent %>%">
                            <%= percent %>%
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

</body>

</html>