<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Voter Registration</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="india-theme">

<nav class="india-nav">
  <div class="nav-brand">
    <div class="ashoka-chakra">⊛</div>
    <div class="logo-text">Voter Registration</div>
  </div>
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/login">Login</a></li>
  </ul>
</nav>

<div class="flag-stripe"></div>

<div class="container" style="max-width:400px;">
  <div class="card india-card">
    <h2 style="text-align:center; color:#0047AB;">Register as a Voter</h2>

    <% if (error) { %>
      <p style="color:red; text-align:center;"><%= error %></p>
    <% } %>
    <% if (success) { %>
      <p style="color:green; text-align:center;"><%= success %></p>
    <% } %>

    <form action="/register" method="POST">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required value="<%= prefill ? prefill.name : '' %>" />
      </div>
      <div class="form-group">
        <label>Voter ID</label>
        <input type="text" name="voterId" required value="<%= prefill ? prefill.voterId : '' %>" />
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" required value="<%= prefill ? prefill.phone : '' %>" />
      </div>
      <button type="submit" class="btn india-btn-primary" style="width:100%;">
        Register
      </button>
    </form>
  </div>
</div>

</body>
</html>