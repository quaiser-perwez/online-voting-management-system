<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>OTP Verification</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="india-theme">

<nav class="india-nav">
  <div class="nav-brand">
    <div class="ashoka-chakra">⊛</div>
    <div class="logo-text">OTP Verification</div>
  </div>
</nav>

<div class="flag-stripe"></div>

<div class="container" style="max-width:400px;">
  <div class="card india-card">

    <h2 style="text-align:center; color:#0047AB;">Enter OTP</h2>

    <% if (otp) { %>
      <div style="background:#E8F5E9; border:2px solid #4CAF50; padding:15px; border-radius:8px; text-align:center; margin-bottom:20px;">
        <p style="margin:0; color:#333; font-size:0.9rem;">Your test OTP is:</p>
        <p style="margin:5px 0 0 0; color:#2E7D32; font-size:2rem; font-weight:bold; letter-spacing:5px;"><%= otp %></p>
        <p style="margin:5px 0 0 0; color:#666; font-size:0.85rem;">Demo only - in production, OTP is sent via SMS/email</p>
      </div>
    <% } %>

    <% if (error) { %>
      <p style="color:red; text-align:center;"><%= error %></p>
    <% } %>

    <form action="/verify-otp" method="POST">
      <div class="form-group">
        <label>4 Digit OTP</label>
        <input type="text" name="otp" maxlength="4" required />
      </div>

      <button type="submit" class="btn india-btn-primary" style="width:100%;">
        Verify OTP
      </button>
    </form>

    <div style="text-align:center; margin-top:15px;">
      <form action="/resend-otp" method="POST">
        <button type="submit" class="btn india-btn-secondary">
          Resend OTP
        </button>
      </form>
    </div>

  </div>
</div>

</body>
</html>